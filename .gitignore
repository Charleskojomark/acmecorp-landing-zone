# Terraform state files — never commit these, they contain sensitive data
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable files that might contain secrets
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# AWS credentials — just in case
.aws/
credentials

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
